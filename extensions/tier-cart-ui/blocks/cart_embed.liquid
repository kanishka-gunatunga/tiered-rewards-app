{%- comment -%}
  Keeps the full progress bar out of the cart drawer.
  Use the "Tier rewards progress" section block on the cart page instead.
  The cart drawer already shows the applied tier discount in the subtotal area.
{%- endcomment -%}
<script>
  (() => {
    if (window.__tierRewardsDrawerGuard) return;
    window.__tierRewardsDrawerGuard = true;

    const stripProgressFromDrawer = () => {
      document
        .querySelectorAll(
          'cart-drawer [data-tier-rewards], #CartDrawer [data-tier-rewards], .cart-drawer [data-tier-rewards], [data-cart-drawer] [data-tier-rewards]',
        )
        .forEach((element) => element.remove());
    };

    stripProgressFromDrawer();
    document.addEventListener("DOMContentLoaded", stripProgressFromDrawer);
    ["cart:updated", "cart:refresh", "theme:cart:change", "theme:cart:update", "tier-rewards:refresh"].forEach(
      (eventName) => document.addEventListener(eventName, stripProgressFromDrawer),
    );
  })();
</script>

{% schema %}
{
  "name": "Cart drawer guard",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Prevents the cart progress bar from appearing inside the cart drawer. On the cart page, add the \"Cart tier progress\" block to your cart items section (below the page title, above line items)."
    }
  ]
}
{% endschema %}
