{% render 'tier-rewards-progress-host',
  heading: block.settings.heading,
  margin_top: block.settings.margin_top,
  margin_bottom: block.settings.margin_bottom,
  block_id: block.id,
  shopify_attributes: block.shopify_attributes
%}
<script>
  (() => {
    const scope = document.querySelector('[data-tier-rewards][data-tier-block-id="{{ block.id }}"]');
    if (!scope) return;
    const target = document.querySelector('form[action="/cart"], .cart__contents, .cart-items, main .page-width');
    if (!target || target.contains(scope)) return;
    const styleEl = document.getElementById('tier-rewards-styles-{{ block.id }}');
    const fragment = document.createDocumentFragment();
    if (styleEl) fragment.appendChild(styleEl);
    fragment.appendChild(scope);
    target.prepend(fragment);
  })();
</script>

{% schema %}
{
  "name": "Cart rewards embed",
  "target": "body",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock More Savings!"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ]
}
{% endschema %}
