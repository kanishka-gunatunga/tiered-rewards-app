{% render 'tier-rewards-progress-host',
  heading: block.settings.heading,
  margin_top: block.settings.margin_top,
  margin_bottom: block.settings.margin_bottom,
  block_id: block.id,
  shopify_attributes: block.shopify_attributes
%}

{% schema %}
{
  "name": "Tier rewards progress",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock More Savings!"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ]
}
{% endschema %}
