        0px 15px 22.5px -4.5px rgba(0, 0, 0, 0.1);
    }
    .tier-rewards-block-v2 .tr-milestone-badge--next svg {
      display: block;
      width: 24px;
      height: 24px;
      flex-shrink: 0;
    }
    .tier-rewards-block-v2 .tr-milestone-money {
      margin-top: 4px;
      font-family: Inter, sans-serif;
      font-weight: 600;
      font-size: 15.87px;
      line-height: 21.16px;
      letter-spacing: 0;
      color: #101828;
    }
    .tier-rewards-block-v2 .tr-milestone-off {
      font-family: Inter, sans-serif;
      font-weight: 500;
      letter-spacing: 0;
    }
    .tier-rewards-block-v2 .tr-milestone-off-green {
      font-size: 15.87px;
      line-height: 21.16px;
      color: #2c8d2c;
    }
    .tier-rewards-block-v2 .tr-milestone-off-orange {
      font-size: 18px;
      line-height: 24px;
      color: #a65f00;
    }
    .tier-rewards-block-v2 .tr-track {
      position: relative;
      display: block;
      width: 100%;
      height: 22px;
      border-radius: 9999px;
      background: #e5e7eb;
      overflow: hidden;
    }
    .tier-rewards-block-v2 .tr-track-fill {
      position: absolute;
      top: 0;
      left: 0;
      display: block;
      height: 100%;
      width: 100%;
      border-radius: 9999px;
      background: linear-gradient(90deg, #e17100 0%, #d08700 50%, #bb4d00 100%);
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 260ms ease;
      will-change: transform;
      pointer-events: none;
    }
